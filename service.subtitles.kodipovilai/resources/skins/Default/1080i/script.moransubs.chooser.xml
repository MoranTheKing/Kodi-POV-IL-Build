<?xml version="1.0" encoding="UTF-8"?>
<!-- MoranSubs subtitle chooser: a self-contained WindowXMLDialog so it renders
     identically on every skin (FENtastic / NOX / Estuary / Arctic Fuse 3). All
     textures are bundled in this add-on skin media; fonts use the universal
     font12/font13/font14 names every skin defines. Populated from Python
     (subs_chooser.py): list id 100; Close=201, Download=202. -->
<window type="dialog">
    <defaultcontrol always="true">100</defaultcontrol>
    <onunload>SetProperty(MoranSubsChooserOpen,,10000)</onunload>
    <controls>

        <!-- Background: the title's fanart, darkened, + a solid dim wash. -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture>$INFO[Player.Art(fanart)]</texture>
            <aspectratio>scale</aspectratio>
            <colordiffuse>44FFFFFF</colordiffuse>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="E6000000">white.png</texture>
        </control>

        <!-- Centered panel -->
        <control type="group">
            <left>210</left><top>120</top>
            <control type="image">
                <left>0</left><top>0</top><width>1500</width><height>840</height>
                <texture colordiffuse="F21A1F27">white.png</texture>
            </control>
            <!-- accent header bar -->
            <control type="image">
                <left>0</left><top>0</top><width>1500</width><height>4</height>
                <texture colordiffuse="FF46C46A">white.png</texture>
            </control>

            <!-- Header: title + found count -->
            <control type="label">
                <left>40</left><top>26</top><width>1180</width><height>48</height>
                <font>font14</font>
                <label>[B]MoranSubs — בחר כתוביות[/B]</label>
                <textcolor>FF8FE0FF</textcolor>
                <aligny>center</aligny>
            </control>
            <control type="label">
                <left>40</left><top>74</top><width>1180</width><height>34</height>
                <font>font12</font>
                <label>$INFO[Window.Property(subs.head)]</label>
                <textcolor>FFB8D6E8</textcolor>
                <aligny>center</aligny>
                <scroll>true</scroll>
            </control>
            <control type="label">
                <left>40</left><top>74</top><width>1420</width><height>34</height>
                <font>font12</font>
                <label>$INFO[Window.Property(subs.count)]</label>
                <textcolor>FF9AA0A6</textcolor>
                <align>right</align><aligny>center</aligny>
            </control>

            <!-- Poster (optional, right side) -->
            <control type="image">
                <left>1230</left><top>130</top><width>230</width><height>345</height>
                <texture fallback="white.png">$INFO[Player.Art(poster)]</texture>
                <aspectratio>scale</aspectratio>
                <bordertexture colordiffuse="33FFFFFF">white.png</bordertexture>
                <bordersize>2</bordersize>
            </control>

            <!-- Results list -->
            <control type="list" id="100">
                <left>30</left><top>122</top><width>1180</width><height>620</height>
                <onleft>100</onleft><onright>202</onright>
                <onup>100</onup><ondown>100</ondown>
                <pagecontrol>0</pagecontrol>
                <scrolltime tween="cubic">400</scrolltime>
                <itemlayout width="1180" height="76">
                    <control type="image">
                        <left>0</left><top>0</top><width>1180</width><height>1</height>
                        <texture colordiffuse="22FFFFFF">white.png</texture>
                    </control>
                    <control type="image">
                        <left>14</left><centertop>50%</centertop>
                        <width>52</width><height>35</height>
                        <texture fallback="white.png">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                    <control type="label">
                        <left>84</left><top>12</top><width>900</width><height>34</height>
                        <font>font13</font>
                        <label>[B]$INFO[ListItem.Label][/B]</label>
                        <textcolor>$INFO[ListItem.Property(col)]</textcolor>
                    </control>
                    <control type="label">
                        <left>84</left><top>43</top><width>900</width><height>26</height>
                        <font>font12</font>
                        <label>$INFO[ListItem.Label2]</label>
                        <textcolor>FF9AA0A6</textcolor>
                    </control>
                    <control type="label">
                        <left>980</left><top>0</top><width>180</width><height>76</height>
                        <font>font14</font>
                        <label>[B]$INFO[ListItem.Property(pct)][/B]</label>
                        <textcolor>$INFO[ListItem.Property(col)]</textcolor>
                        <align>right</align><aligny>center</aligny>
                    </control>
                </itemlayout>
                <focusedlayout width="1180" height="76">
                    <control type="image">
                        <left>0</left><top>0</top><width>1180</width><height>1</height>
                        <texture colordiffuse="22FFFFFF">white.png</texture>
                    </control>
                    <control type="image">
                        <left>0</left><top>1</top><width>1180</width><height>74</height>
                        <texture colordiffuse="26FFFFFF">white.png</texture>
                    </control>
                    <control type="image">
                        <left>0</left><top>1</top><width>5</width><height>74</height>
                        <texture colordiffuse="FF46C46A">white.png</texture>
                    </control>
                    <control type="image">
                        <left>14</left><centertop>50%</centertop>
                        <width>52</width><height>35</height>
                        <texture fallback="white.png">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                    <control type="label">
                        <left>84</left><top>12</top><width>900</width><height>34</height>
                        <font>font13</font>
                        <label>[B]$INFO[ListItem.Label][/B]</label>
                        <textcolor>$INFO[ListItem.Property(col)]</textcolor>
                    </control>
                    <control type="label">
                        <left>84</left><top>43</top><width>900</width><height>26</height>
                        <font>font12</font>
                        <label>$INFO[ListItem.Label2]</label>
                        <textcolor>FFC8D0D8</textcolor>
                    </control>
                    <control type="label">
                        <left>980</left><top>0</top><width>180</width><height>76</height>
                        <font>font14</font>
                        <label>[B]$INFO[ListItem.Property(pct)][/B]</label>
                        <textcolor>$INFO[ListItem.Property(col)]</textcolor>
                        <align>right</align><aligny>center</aligny>
                    </control>
                </focusedlayout>
            </control>

            <!-- Buttons -->
            <control type="button" id="202">
                <left>1230</left><top>520</top><width>230</width><height>56</height>
                <texturefocus colordiffuse="FF46C46A">white.png</texturefocus>
                <texturenofocus colordiffuse="3346C46A">white.png</texturenofocus>
                <label>הורדת כתוביות (Kodi)</label>
                <font>font12</font><align>center</align>
                <onleft>100</onleft><onup>201</onup><ondown>201</ondown>
            </control>
            <control type="button" id="201">
                <left>1230</left><top>586</top><width>230</width><height>56</height>
                <texturefocus colordiffuse="FFD0594F">white.png</texturefocus>
                <texturenofocus colordiffuse="33D0594F">white.png</texturenofocus>
                <label>סגור</label>
                <font>font12</font><align>center</align>
                <onleft>100</onleft><onup>202</onup><ondown>202</ondown>
            </control>
        </control>
    </controls>
</window>
