<?xml version="1.0" encoding="UTF-8"?>
<!-- MoranSubs subtitle chooser: a self-contained, FULL-SCREEN WindowXMLDialog so
     it renders the same rich design on every non-FENtastic skin (NOX / Estuary /
     Arctic Fuse 3). Tal-inspired: fanart background, poster + plot, a wide
     two-line results list with a language flag and a colour-coded match %, and a
     smooth focus highlight. All textures bundled in this add-on skin media; only
     the universal font12/13/14 names are used. Row colours are baked into the
     labels (BBCode) from Python so they render per-row reliably. Populated by
     subs_chooser.py: list id 100; Close=201, Download=202. -->
<window type="dialog">
    <defaultcontrol always="true">100</defaultcontrol>
    <onunload>SetProperty(MoranSubsChooserOpen,,10000)</onunload>
    <controls>

        <!-- Full-screen fanart background, darkened, + a dim wash + side shadow. -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture fallback="white.png">$INFO[Player.Art(fanart)]</texture>
            <aspectratio>scale</aspectratio>
            <colordiffuse>4DFFFFFF</colordiffuse>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="E6000000">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1320</width><height>1080</height>
            <texture colordiffuse="B3000000">white.png</texture>
        </control>
        <!-- top accent line -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>5</height>
            <texture colordiffuse="FF46C46A">white.png</texture>
        </control>

        <!-- Header -->
        <control type="label">
            <left>60</left><top>40</top><width>1180</width><height>54</height>
            <font>font14</font>
            <label>[B][COLOR FF8FE0FF]MoranSubs — בחר כתוביות[/COLOR][/B]</label>
            <aligny>center</aligny>
        </control>
        <control type="label">
            <left>60</left><top>94</top><width>900</width><height>34</height>
            <font>font13</font>
            <label>$INFO[Window.Property(subs.head)]</label>
            <textcolor>FFB8D6E8</textcolor>
            <aligny>center</aligny><scroll>true</scroll>
        </control>
        <control type="label">
            <left>60</left><top>94</top><width>1180</width><height>34</height>
            <font>font13</font>
            <label>$INFO[Window.Property(subs.count)]</label>
            <textcolor>FF9AA0A6</textcolor>
            <align>right</align><aligny>center</aligny>
        </control>

        <!-- Results list (wide, left) -->
        <control type="list" id="100">
            <left>40</left><top>150</top><width>1240</width><height>820</height>
            <onleft>100</onleft><onright>202</onright>
            <onup>100</onup><ondown>100</ondown>
            <pagecontrol>0</pagecontrol>
            <scrolltime tween="cubic">350</scrolltime>
            <itemlayout width="1240" height="84">
                <control type="image">
                    <left>0</left><top>0</top><width>1240</width><height>1</height>
                    <texture colordiffuse="1AFFFFFF">white.png</texture>
                </control>
                <control type="image">
                    <left>18</left><centertop>50%</centertop>
                    <width>56</width><height>38</height>
                    <texture fallback="white.png">$INFO[ListItem.Art(thumb)]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
                <control type="label">
                    <left>96</left><top>14</top><width>940</width><height>36</height>
                    <font>font13</font>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>96</left><top>48</top><width>940</width><height>28</height>
                    <font>font12</font>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
                <control type="label">
                    <left>1040</left><top>0</top><width>180</width><height>84</height>
                    <font>font14</font>
                    <label>$INFO[ListItem.Property(pct)]</label>
                    <align>right</align><aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="1240" height="84">
                <control type="image">
                    <left>0</left><top>0</top><width>1240</width><height>1</height>
                    <texture colordiffuse="1AFFFFFF">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>1</top><width>1240</width><height>82</height>
                    <texture colordiffuse="2EFFFFFF">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>1</top><width>6</width><height>82</height>
                    <texture colordiffuse="FF46C46A">white.png</texture>
                </control>
                <control type="image">
                    <left>18</left><centertop>50%</centertop>
                    <width>56</width><height>38</height>
                    <texture fallback="white.png">$INFO[ListItem.Art(thumb)]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
                <control type="label">
                    <left>96</left><top>14</top><width>940</width><height>36</height>
                    <font>font13</font>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>96</left><top>48</top><width>940</width><height>28</height>
                    <font>font12</font>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
                <control type="label">
                    <left>1040</left><top>0</top><width>180</width><height>84</height>
                    <font>font14</font>
                    <label>$INFO[ListItem.Property(pct)]</label>
                    <align>right</align><aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>

        <!-- Right column: poster + plot + buttons -->
        <control type="image">
            <left>1360</left><top>150</top><width>340</width><height>500</height>
            <texture fallback="white.png">$INFO[Player.Art(poster)]</texture>
            <aspectratio>scale</aspectratio>
            <bordertexture colordiffuse="33FFFFFF">white.png</bordertexture>
            <bordersize>2</bordersize>
        </control>
        <control type="textbox">
            <left>1360</left><top>668</top><width>500</width><height>200</height>
            <font>font12</font>
            <label>$INFO[VideoPlayer.Plot]</label>
            <textcolor>FFB8C2CC</textcolor>
            <autoscroll time="4000" delay="6000" repeat="6000">true</autoscroll>
        </control>
        <control type="button" id="202">
            <left>1360</left><top>888</top><width>340</width><height>62</height>
            <texturefocus colordiffuse="FF46C46A">white.png</texturefocus>
            <texturenofocus colordiffuse="3346C46A">white.png</texturenofocus>
            <label>[B]הורדת כתוביות (Kodi)[/B]</label>
            <font>font13</font><align>center</align>
            <onleft>100</onleft><onup>201</onup><ondown>201</ondown>
        </control>
        <control type="button" id="201">
            <left>1360</left><top>958</top><width>340</width><height>62</height>
            <texturefocus colordiffuse="FFD0594F">white.png</texturefocus>
            <texturenofocus colordiffuse="33D0594F">white.png</texturenofocus>
            <label>[B]סגור[/B]</label>
            <font>font13</font><align>center</align>
            <onleft>100</onleft><onup>202</onup><ondown>202</ondown>
        </control>
    </controls>
</window>
