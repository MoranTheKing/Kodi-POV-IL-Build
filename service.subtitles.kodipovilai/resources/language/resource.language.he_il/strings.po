msgctxt "#32100"
msgid "Gemini API"
msgstr "חיבור Gemini"

msgctxt "#32101"
msgid "Get a free Gemini API key (opens browser)"
msgstr "צור API key חינמי ב-Google AI Studio"

msgctxt "#32102"
msgid "Gemini API Key"
msgstr "Gemini API Key"

msgctxt "#32103"
msgid "Stored in plain text"
msgstr "אזהרה: ה-key נשמר בלי הצפנה"

msgctxt "#32104"
msgid "Do not share your Kodi backup with anyone. Revoke and re-create the key in AI Studio if you suspect it was leaked."
msgstr "אל תשתף את ה-Kodi backup שלך. אם חששת שה-key נחשף - בטל ויצור חדש ב-AI Studio."

msgctxt "#32105"
