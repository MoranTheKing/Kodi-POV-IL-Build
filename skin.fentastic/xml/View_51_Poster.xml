<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="View_51_Poster">
		<control type="button" id="20000">
			<description>Dummy button to get animations right (hide focusedlayout on animations)</description>
			<include>HiddenObject</include>
			<animation effect="fade" delay="500" time="0" start="100" end="0">Visible</animation>
			<animation effect="fade" delay="500" time="0" start="100" end="0">WindowOpen</animation>
			<onclick>noop</onclick>
			<visible>Control.IsVisible(51)</visible>
		</control>
		<control type="group">
			<description>Poster Viewtype</description>
			<centertop>50%</centertop>
			<height>720</height>

			<!-- KODI-RD-IL ADDITION -->
			<include content="Poster_View_Art_Logo">
			</include>
			<!-- ##################### -->
		
			<control type="group">
				<visible>Control.IsVisible(51)</visible>
				<include>Visible_Right</include>
				<include>OpenClose_Right</include>
				<control type="fixedlist" id="51">
					<left>-10</left>
					<top>0</top>
					<width>110%</width>
					<height>704</height>
					<focusposition>1</focusposition>
					<movement>0</movement>
					<pagecontrol>5199</pagecontrol>
					<scrolltime tween="cubic" easing="out">500</scrolltime>
					<orientation>horizontal</orientation>
					<onleft>51</onleft>
					<onup>9000</onup>
					<ondown>5199</ondown>
					<onright>51</onright>
					<hitrect x="100" y="0" w="800" h="400" />
					<visible>Container.Content(movies) | Container.Content(seasons) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(games)</visible>
					<preloaditems>1</preloaditems>
					<viewtype label="20021">icon</viewtype>
					<itemlayout width="215">
						<control type="group">
							<left>-118</left>
							<top>18</top>
							<include>InfoWallMovieLayout</include>
						</control>
					</itemlayout>
					<focusedlayout width="490">
						<control type="group">
							<control type="group">
								<left>-220</left>
								<top>18</top>
								<visible>Container.OnScrollPrevious</visible>
								<visible>Control.IsVisible(20000)</visible>
								<animation effect="fade" time="200" start="100" end="0">Hidden</animation>
								<include>InfoWallMovieLayout</include>
							</control>
							<control type="group">
								<left>-40</left>
								<top>18</top>
								<visible>Container.OnScrollNext</visible>
								<visible>Control.IsVisible(20000)</visible>
								<animation effect="fade" time="200" start="100" end="0">Hidden</animation>
								<include>InfoWallMovieLayout</include>
							</control>
						</control>
					</focusedlayout>
				</control>
				<!-- Title and Plot -->
				<control type="grouplist">
				<width>1200</width>
				<height>350</height>
				<top>350</top>
				<left>600</left>
				<itemgap>5</itemgap>
				<align>vertical</align>
				<control type="label">
					<height max="55">auto</height>
					<font>font45_title</font>	
					<label>$INFO[ListItem.Label] $INFO[ListItem.Year,(,)]</label>
				</control>
				<control type="textbox">
					<height max="105">auto</height>
					<font>font25_title</font>
					<label>$VAR[globalviewtypeinfo]</label>
				</control>
				<control type="textbox">
					<height max="165">auto</height>
					<align>left</align>
					<!-- שינוי לנתון האמיתי של TMDb Helper שמציג את הסטטוס -->
					<label>$INFO[ListItem.Plot]</label>
					<visible>!String.IsEmpty(ListItem.Plot)</visible>
					<autoscroll fade="3500" time="3500" repeat="3500">true</autoscroll>
				</control>	
				<control type="textbox">
					<height max="40">auto</height>
					<align>left</align>
					<font>font32_title</font>
					<!-- מציג את סטטוס הסדרה בין השנים -->
					<label>בין השנים $INFO[Control.GetLabel(55005)]</label>
					<visible>$EXP[__tvshow]</visible>
				</control>
			</control>
			</control>
		</control>
		<control type="group">
			<centertop>50%</centertop>
			<height>670</height>
			<left>101</left>
			<depth>DepthContentPopout</depth>
			<visible>Control.IsVisible(51)</visible>
			<include>OpenClose_Left</include>
			<include>Visible_Left</include>
			<control type="group">
				<control type="image">
					<left>4</left>
					<top>4</top>
					<width>476</width>
					<height>716</height>
					<fadetime>200</fadetime>
					<!-- <aspectratio>scale</aspectratio> -->
					<texture diffuse="masks/poster-50.png" fallback="DefaultMovies.png" background="true">$VAR[PosterThumbVar]</texture>
				</control>
				<control type="image">
					<left>4</left>
					<top>570</top>
					<width>476</width>
					<height>150</height>
					<texture colordiffuse="CCFFFFFF">overlays/overlayfade51.png</texture>
					<visible>String.IsEqual(ListItem.DBtype,movie) + !String.IsEmpty(Container($PARAM[id]).ListItem.Property(WatchedProgress)) + !Integer.IsEqual(Container($PARAM[id]).ListItem.Property(WatchedProgress),0)</visible>
				</control>
				<control type="label">
					<left>275</left>
					<top>680</top>
					<width>180</width>
					<!-- KODI-RD-IL CHANGES -->
					<label>$INFO[ListItem.Property(WatchedProgress)]% $LOCALIZE[700013]</label>
					<!-- ##################### -->
					<font>font20_title</font>
					<shadowcolor>text_shadow</shadowcolor>
					<align>right</align>
					<visible>String.IsEqual(ListItem.DBtype,movie) + !String.IsEmpty(Container($PARAM[id]).ListItem.Property(WatchedProgress)) + !Integer.IsEqual(Container($PARAM[id]).ListItem.Property(WatchedProgress),0)</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
				
				<!-- KODI-RD-IL ADDITION -->
					<control type="image">
					<animation effect="fade" start="0" end="100" time="400">VisibleChange</animation>
					<visible>!String.IsEmpty(ListItem.Studio)</visible>
					<left>22</left>
					<top>0</top>
					<width>120</width>
					<height>90</height>
					<aspectratio align="left" aligny="center" scalediffuse="false">keep</aspectratio>
					<texture>kodirdil/studiologos/$INFO[ListItem.Studio].png</texture>
				</control>
				<!-- ##################### -->
				
				<control type="group">
				<left>433</left>
				<top>-14</top>
				<include content="RatingCircle">
					<param name="animation" value="True" />
					<param name="left">-73</param>
					<param name="top">18</param>
					<param name="width">119</param>
					<param name="height">119</param>
					<param name="label-left">-16</param>
					<param name="label-top">38</param>
					<param name="cornerdiffuse">overlays/overlaybg4.png</param>
				</include>
			</control>
			</control>
			<control type="group">
				<visible>String.IsEqual(ListItem.DBtype,tvshow)</visible>
				<control type="image">
					<left>4</left>
					<top>570</top>
					<width>476</width>
					<height>150</height>
					<texture colordiffuse="CCFFFFFF">overlays/overlayfade51.png</texture>
					<visible>!String.IsEmpty(ListItem.Art(poster))</visible>
				</control>
				<control type="label">
					<left>-20</left>
					<top>684</top>
					<width>435</width>
					<height>24</height>
					<!-- KODI-RD-IL CHANGES -->
					<label>$INFO[ListItem.Property(TotalSeasons)] $VAR[SeasonCorrectLabel] / $INFO[ListItem.Property(TotalEpisodes)] $LOCALIZE[7000161]</label>
					<!-- ##################### -->
					<font>font20_title</font>
					<shadowcolor>text_shadow</shadowcolor>
					<align>right</align>
					<aligny>center</aligny>
				</control>
				<control type="image">
					<left>425</left>
					<top>684</top>
					<width>24</width>
					<height>24</height>
					<texture>lists/played-total.png</texture>
					<align>right</align>
					<aligny>center</aligny>
				</control>
			</control>
			<control type="progress">
				<left>4</left>
				<top>702</top>
				<width>476</width>
				<height>1</height>
				<texturebg></texturebg>
				<midtexture colordiffuse="button_focus2" border="3">progress/texturebg_alt_white.png</midtexture>
				<info>ListItem.PercentPlayed</info>
				<visible>!Integer.IsEqual(ListItem.PercentPlayed,0)</visible>
			</control>
		</control>
	</include>
	
	<!-- KODI-RD-IL ADDITION -->
	<include name="Poster_View_Art_Logo">
	<param name="top" default="-105"/>
	<param name="left" default="50%"/>
		<definition>
			<control type="group">
				<visible>Control.IsVisible(51)</visible>
				<control type="image">
					<top>-150</top>
					<left>42%</left>
					<width>320</width>
					<height>130</height>
					<aspectratio scalediffuse="false" align="left" aligny="center">keep</aspectratio>
					<texture>$VAR[ClearArtLogo]</texture>
				</control>
			</control>
		</definition>
	</include>
	<!-- ##################### -->
	
</includes>
