<?xml version="1.0" encoding="UTF-8"?>
<includes>

<include name="BasedResizedWidgetImage">
<param name="resize">5</param>
<param name="bottom">5</param>
<param name="centerleft">$PARAM[centerleft]</param>
<param name="centertop">$PARAM[centertop]</param>
<definition>
	<centertop>$PARAM[centertop]</centertop>
	<centerleft>$PARAM[centerleft]</centerleft>
	<left>$PARAM[resize]</left>
	<right>$PARAM[resize]</right>
	<top>$PARAM[resize]</top>
	<bottom>$PARAM[bottom]</bottom>
</definition>
</include>

<include name="BasedResizedLabelOBJ">
<param name="height">25</param>
<param name="align">center</param>
<param name="aligny">center</param>
<param name="font">$PARAM[font]</param>
<param name="textcolor">$PARAM[textcolor]</param>
<param name="centerleft">$PARAM[centerleft]</param>
<param name="centertop">$PARAM[centertop]</param>
<definition>
	<centertop>$PARAM[centertop]</centertop>
	<centerleft>$PARAM[centerleft]</centerleft>
	<height>$PARAM[height]</height>
	<align>$PARAM[align]</align>
	<aligny>$PARAM[aligny]</aligny>
	<font>$PARAM[font]</font>
	<textcolor>$PARAM[textcolor]</textcolor>
</definition>
</include>

<include name="BasedResizedWidgetFrame">
<param name="texture">icons/box21.png</param>
<param name="colordiffuse">FF181818</param>
<definition>
<control type="image">
	<nested />
	<texture border="16">$PARAM[texture]</texture>
	<colordiffuse>$PARAM[colordiffuse]</colordiffuse>
</control>
</definition>
</include>

<include name="BasedResizedWidgetFrameBox">
<param name="boxcolordiffuse">98181818</param>
<definition>
<control type="image">
	<nested />
	<texture border="16">icons/box.png</texture>
	<colordiffuse>$PARAM[boxcolordiffuse]</colordiffuse>
</control>
</definition>
</include>

<include name="BasedResizedWidgetTexture">
<control type="image">
<nested />
	<texture>$PARAM[texture]</texture>
</control>
</include>

<include name="BasedLabelWidgetOBJ">
<param name="label">$VAR[osd_top_info_var]</param>
<definition>
<control type="label">
<nested />
	<label>$PARAM[label]</label>
</control>
</definition>
</include>

<include name="dateandtimebgobj">
	<control type="image">
		<centerleft>50%</centerleft>
		<top>$PARAM[headlinebackgroundtop]</top>
		<width>$PARAM[headlinebackgroundwidth]</width>
		<height>$PARAM[headlinebackgroundheight]</height>
		<texture border="16" colordiffuse="98000000">masks/categorywidget.png</texture>
		<bordertexture border="16">masks/categorywidget-unfocused.png</bordertexture>
	</control>
</include>
</includes>
