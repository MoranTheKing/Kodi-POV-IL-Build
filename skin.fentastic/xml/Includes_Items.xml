		<property name="id">$NUMBER[52000]</property>
	</item>
	<item>
		<icon>osd/fullscreen/buttons/pause.png</icon>
		<onclick>PlayerControl(play)</onclick>
		<visible>!Player.Paused</visible>
		<property name="id">$NUMBER[52000]</property>
	</item>
	<item>
		<icon>osd/fullscreen/buttons/stop.png</icon>
		<onclick>PlayerControl(stop)</onclick>
		<property name="id">$NUMBER[52000]</property>
	</item>
	<item>
	<icon>osd/fullscreen/buttons/subs3.png</icon>
	<onclick>ActivateWindow(subtitlesearch)</onclick>
	</item>
	<item>
		<icon>osd/fullscreen/buttons/previous.png</icon>
		<onclick></onclick>
		<property name="id">$NUMBER[52000]</property>
		</item>
	</content>
</include>

<include name="changeplayer_osd">
<item>
	<label>[B][COLOR blue]שנה נגן[/COLOR][/B]</label>
	<label2>$VAR[__PlayerChoose]</label2>
	<onclick condition="String.IsEmpty(Skin.String(__chooseplayer,__simpleplayer)">Skin.SetString(__chooseplayer,__simpleplayer)</onclick>
	<onclick condition="Skin.String(__chooseplayer,__simpleplayer)">Skin.SetString(__chooseplayer,__advancedplayer)</onclick>
	<onclick condition="Skin.String(__chooseplayer,__advancedplayer)">Skin.SetString(__chooseplayer,__netflixplayer)</onclick>
	<onclick condition="Skin.String(__chooseplayer,__netflixplayer)">Skin.SetString(__chooseplayer,__simpleplayer)</onclick>
</item>
</include>

