	<left>5</left>
	<orientation>vertical</orientation>
	<itemlayout width="410" height="85">
	<control type="image">
		<left>5</left>
		<right>5</right>
		<top>5</top>
		<texture colordiffuse="65FFFFFF">masks/categorywidget-unfocused.png</texture>
	</control>
	<control type="image">
		<left>25</left>
		<top>32</top>
		<width>25</width>
		<height>25</height>
