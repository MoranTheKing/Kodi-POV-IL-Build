	</control>
	<control type="image">
		<left>25</left>
		<top>32</top>
		<width>25</width>
		<height>25</height>
		<aspectratio>keep</aspectratio>
		<texture>$INFO[ListItem.Icon]</texture>
	</control>
	<control type="label">
		<left>100</left>
		<top>20</top>
		<label>$INFO[ListItem.Label]</label>
	</control>
