<include name="OsdNetflixEpisodesInSeasonsLayout">
<param name="layoutwidth">640</param>
<param name="layoutheight">350</param>
<param name="groupwidth">600</param>
<param name="id">200323</param>
<param name="plotbottom">20</param>
<definition>
<itemlayout width="$PARAM[layoutwidth]" height="$PARAM[layoutheight]">
<control type="group">
<width>$PARAM[groupwidth]</width>
<include content="BasedResizedWidgetFrame">
	<include content="BasedResizedWidgetImage">
		<param name="resize">0</param>
		<param name="bottom">0</param>
	</include>
</include>
<include content="BasedResizedWidgetFrameBox">
	<param name="boxcolordiffuse">98181818</param>
	<include content="BasedResizedWidgetImage">
		<param name="resize">2</param>
		<param name="bottom">2</param>
	</include>
</include>
<include content="BasedResizedWidgetTexture">
	<param name="texture">$INFO[Player.Icon]</param>
<include content="BasedResizedWidgetImage">
	<param name="resize">5</param>
	<param name="bottom">5</param>
</include>
</include>
</control>
</itemlayout>
<focusedlayout width="$PARAM[layoutwidth]" height="$PARAM[layoutheight]">
<control type="group">
<width>$PARAM[groupwidth]</width>
<include content="BasedResizedWidgetFrame">
	<include content="BasedResizedWidgetImage">
		<param name="resize">0</param>
		<param name="bottom">0</param>
	</include>
</include>
<include content="BasedResizedWidgetFrameBox">
	<param name="boxcolordiffuse">98181818</param>
	<include content="BasedResizedWidgetImage">
		<param name="resize">2</param>
		<param name="bottom">2</param>
	</include>
</include>
<include content="BasedResizedWidgetTexture">
	<param name="texture">$INFO[Player.Icon]</param>
<include content="BasedResizedWidgetImage">
	<param name="resize">5</param>
	<param name="bottom">5</param>
</include>
</include>
<control type="image">
	<left>2</left>
	<right>2</right>
	<top>2</top>
	<bottom>2</bottom>
	<animation condition="true" effect="fade" start="100" end="88" time="0">Conditional</animation>
	<texture border="16">icons/box.png</texture>
	<colordiffuse>black</colordiffuse>
	<visible>control.hasfocus($PARAM[id])</visible>
</control>
</control>
<control type="group">
<visible>control.hasfocus($PARAM[id])</visible>
<width>$PARAM[groupwidth]</width>
<left>$PARAM[infoleft]</left>
<centerleft>50%</centerleft>
<control type="label">
	<right>40</right>
	<top>10</top>
	<align>center</align>
	<font>font45_title</font>
	<label>$INFO[ListItem.TvShowTitle]</label>
</control>
<control type="label">
	<right>40</right>
	<top>70</top>
	<align>center</align>
	<textcolor>deeppink</textcolor>
	<label>$INFO[ListItem.Genre]</label>
</control>
<control type="label">
	<right>40</right>
	<top>110</top>
	<align>center</align>
	<textcolor>yellow</textcolor>
	<label>עונה [COLOR yellow]$INFO[ListItem.Season,(,)][/COLOR] פרק [COLOR yellow]$INFO[ListItem.Episode,(,)][/COLOR]</label>
</control>
<control type="textbox">
	<right>40</right>
	<bottom>$PARAM[plotbottom]</bottom>
	<top>155</top>
	<align>center</align>
	<label>$INFO[ListItem.Plot]</label>
	<autoscroll fade="3500" time="3500" repeat="3500">control.hasfocus($PARAM[id])</autoscroll>
</control>
</control>
</focusedlayout>
</definition>
</include>

