<!-- PLAYER SOURCE -->
<control type="group">
<left>10</left>
<right>10</right>
<height>140</height>
<bottom>195</bottom>
<include>bottom2topslideanimation</include>
	<visible>String.IsEqual(Container(201).ListItem.Property(plyersource),plyersource)</visible>
	<control type="group">
		<width>400</width>
		<height>400</height>
		<bottom>0</bottom>
		<include content="basedframeimage">
			<param name="texture">$VAR[_FixOsdIcon]</param>
		</include>
	</control>
	<control type="list" id="49994">
		<bottom>0</bottom>
		<left>420</left>
		<onback>201</onback>
		<onup>false</onup>
		<ondown>false</ondown>
		<orientation>vertical</orientation>
		<itemlayout width="620" height="70">
		<control type="group">
		<height>60</height>
		<control type="image">
			<texture border="16">buttons/button-nofocus.png</texture>
		</control>
		<control type="label">
			<align>center</align>
			<aligny>center</aligny>
			<label>$INFO[ListItem.Label]</label>
		</control>
		</control>
		</itemlayout>
		<focusedlayout width="620" height="70">
		<control type="group">
		<height>60</height>
		<control type="image">
			<texture border="16">buttons/button-nofocus.png</texture>
		</control>
		<control type="image">
			<texture border="16">buttons/button-focus.png</texture>
			<visible>Control.HasFocus(49994)</visible>
		</control>
		<control type="label">
			<align>center</align>
			<aligny>center</aligny>
			<label>$INFO[ListItem.Label]</label>
			<visible>!Control.HasFocus(49994)</visible>
		</control>
		<control type="label">
			<align>center</align>
			<aligny>center</aligny>
			<label>$INFO[ListItem.Label]</label>
			<textcolor>blue</textcolor>
			<visible>Control.HasFocus(49994)</visible>
		</control>
		</control>
		</focusedlayout>
		<content>
		<item>
			<label>החלף ובחר מקור חדש לסרט</label>
			<onclick>RunPlugIn($VAR[OsdReplaceSourceStartPoint]&mediatype=movie&tmdb_id=$VAR[_Fix_TMDB_ID]$VAR[AutoPlaySetToFalse])</onclick>
			<visible>VideoPlayer.Content(movies)</visible>
		</item>
		<item>
			<label>החלף ונגן אוטומט מקור אחר לסרט</label>
			<onclick>RunPlugIn($VAR[OsdReplaceSourceStartPoint]&mediatype=movie&tmdb_id=$VAR[_Fix_TMDB_ID]$VAR[AutoPlaySetToTrue])</onclick>
			<visible>VideoPlayer.Content(movies)</visible>
