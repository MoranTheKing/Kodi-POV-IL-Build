<?xml version="1.0" encoding="UTF-8"?>
<includes>


<include name="videosd1">
<control type="group">
	<left>10</left>
	<right>10</right>
	<include>bottom2topslideanimation</include>
		<control type="image">
			<left>-40</left>
			<width>120%</width>
			<height>600</height>
			<bottom>0</bottom>
			<texture flipy="true">frame/osdfade.png</texture>
		</control>
		<control type="image">
			<left>-40</left>
			<width>120%</width>
			<height>200</height>
			<top>0</top>
			<texture>frame/osdfade.png</texture>
		</control>
		<control type="label">
			<align>right</align>
			<left>1200</left>
			<height>50</height>
			<bottom>10</bottom>
			<scroll>true</scroll>
			<scrolltime>40</scrolltime>
			<label>$INFO[ListItem.Label]</label>
			<visible>![Player.Rewinding | Player.Forwarding]</visible>
		</control>	
		<control type="label">
			<align>right</align>
			<height>50</height>
			<bottom>10</bottom>
			<label>מעביר [COLOR button_focus]$VAR[SeekRewindForwardTime][/COLOR]</label>
			<visible>Player.Rewinding | Player.Forwarding</visible>
		</control>	
		<!-- OSD MAIN MENU -->
		<control type="list" id="201">
		<orientation>horizontal</orientation>
		<height>60</height>
		<bottom>0</bottom>
		<onup>SetFocus($INFO[Container(201).ListItem.Property(onup)])</onup>
		<itemlayout width="60" height="50">
		<control type="group">
		<width>50</width>
			<include content="_IconObject">
				<param name="focused">true</param>
				<param name="nofocus">false</param>
				<param name="framefocus">false</param>
			</include>
			<control type="image">
				<width>35</width>
				<height>35</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture colordiffuse="orange">$INFO[ListItem.Property(subon)]</texture>
				<visible>VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
			</control>
			<control type="image">
				<width>35</width>
				<height>35</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture>$INFO[ListItem.Property(suboff)]</texture>
				<visible>!VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
			</control>
			<control type="image">
				<width>28</width>
				<height>28</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture>$INFO[ListItem.Property(timer)]</texture>
			</control>
		</control>
		</itemlayout>
		<focusedlayout width="60" height="50">
		<control type="group">
		<width>50</width>
			<include content="_IconObject">
				<param name="focused">true</param>
				<param name="framefocus">true</param>
				<param name="nofocus">true</param>
				<param name="animnofocus">!Control.HasFocus(201)</param>
			</include>
			<control type="image">
				<width>35</width>
				<height>35</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture colordiffuse="orange">$INFO[ListItem.Property(subon)]</texture>
				<visible>VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
			</control>
			<control type="image">
				<width>35</width>
				<height>35</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<colordiffuse>$INFO[Skin.String(osdbuttonfocuscolor)]</colordiffuse>
				<texture>$INFO[ListItem.Property(suboff)]</texture>
				<visible>!VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
				<visible>Control.HasFocus(201)</visible>
			</control>
			<control type="image">
				<width>35</width>
				<height>35</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<colordiffuse>$INFO[Skin.String(osdbuttonfocuscolor)]</colordiffuse>
				<texture>$INFO[ListItem.Property(suboff)]</texture>
				<visible>!VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
				<visible>!Control.HasFocus(201)</visible>
			</control>
			<control type="image">
				<width>28</width>
				<height>28</height>
				<centertop>50%</centertop>
				<centerleft>50%</centerleft>
				<texture>$INFO[ListItem.Property(timer)]</texture>
				<colordiffuse>$INFO[Skin.String(osdbuttonfocuscolor)]</colordiffuse>
			</control>
		</control>
		</focusedlayout>
		<content>
		<item id="100">
			<label>מעבר לתכנית הקודמת או לפרק הקודם</label>
			<icon>osd/fullscreen/buttons/previous.png</icon>
			<onclick>SkipPrevious</onclick>
			<visible>Player.Chapter | !String.IsEmpty(VideoPlayer.offset(-1).Title)</visible>
		</item>
		<item>
			<label>הרץ קדימה</label>
			<icon>osd/fullscreen/buttons/rewind.png</icon>
			<visible>Player.SeekEnabled</visible>
			<property name="rewind">rewind</property>
			<property name="onup">$NUMBER[50002]</property>
			<onclick>Control.SetFocus(50002)</onclick>
		</item>
		<item id="500">
			<label>מידע / אפשר ללחוץ על הכפתור למידע מורחב יותר</label>
			<icon>osd/fullscreen/buttons/information.png</icon>
			<property name="info">info</property>
			<visible>!String.IsEmpty(VideoPlayer.Plot)</visible>
			<onclick>Dialog.Close(videoosd)</onclick>
			<onclick>ActivateWindow(1125)</onclick>
		</item>
		<item id="101">
			<label>עצור</label>
			<icon>osd/fullscreen/buttons/stop.png</icon>
			<onclick>PlayerControl(stop)</onclick>
		</item>
		<item id="102">
			<label>המשך ניגון</label>
			<icon>osd/fullscreen/buttons/play.png</icon>
			<onclick>PlayerControl(play)</onclick>
			<visible>Player.PauseEnabled + Player.Paused</visible>
		</item>
		<item id="103">
			<label>לחץ להשהות את הניגון</label>
			<icon>osd/fullscreen/buttons/pause.png</icon>
			<onclick>PlayerControl(play)</onclick>
			<visible>Player.PauseEnabled + !Player.Paused</visible>
		</item>
		<item id="104">
			<property name="timer">icons\infodialogs\timer.png</property>
			<label>הנגן יסגר בעוד $INFO[Skin.String(OSDAutoCloseTime)] שניות</label>
			<onclick>Skin.SetNumeric(OSDAutoCloseTime,20)</onclick>
		</item>
		<item id="105">
			<label>כתובית מופעלת</label>
			<property name="subon">osd/fullscreen/buttons/settings-subtitle.png</property>
			<onclick>showsubtitles</onclick>
			<visible>VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
		</item>
		<item id="106">
			<label>כתובית כבוייה</label>
			<property name="suboff">osd/fullscreen/buttons/settings-subtitle.png</property>
			<onclick>showsubtitles</onclick>
			<visible>!VideoPlayer.SubtitlesEnabled + VideoPlayer.HasSubtitles</visible>
		</item>
		<item id="107">
			<label>חפש כתובית</label>
			<icon>osd/fullscreen/buttons/subs.png</icon>
			<visible>VideoPlayer.Content(movies) | VideoPlayer.Content(episodes)</visible>
			<onclick condition="String.IsEqual(Skin.String(subtitlesearch),darksubs)">RunScript(service.subtitles.All_Subs,sub_window_unpause)</onclick>
			<onclick condition="String.IsEqual(Skin.String(subtitlesearch),kodisubtitle)">ActivateWindow(subtitlesearch)</onclick>
		</item>	
		<item>
			<label>החלף מקור לניגון</label>
			<icon>osd/fullscreen/buttons/guide.png</icon>
			<property name="plyersource">plyersource</property>
			<property name="onup">$NUMBER[49994]</property>
			<onclick>Control.SetFocus(49994)</onclick>
			<visible>!VideoPlayer.Content(LiveTv) + !String.Contains(Player.FolderPath,idanplus)</visible>
		</item>
		<item>
			<label>ערוצי עידן פלוס</label>
			<property name="timer">icons\submenu\channels.png</property>
			<property name="onup">$NUMBER[60015]</property>
			<property name="idanchannels">idanchannels</property>
			<onclick>Control.SetFocus(60015)</onclick>
		</item>
		<item id="108">
		<label>הגדרות ויאודו / אודיו / נגן</label>
			<icon>osd/fullscreen/buttons/settings.png</icon>
			<onclick>ActivateWindow(1124)</onclick>
		</item>
		<item id="110">
			<label>הקטן את משך ההשהיה של כתוביות (השתמש אם הכתוביות מוצגות מאוחר מדי)</label>
			<property name="timer">https://www.iconsdb.com/icons/preview/white/arrow-142-xxl.png</property>
			<onclick>SubtitleDelayMinus</onclick>
			<visible>$EXP[osdmoviestvshowvisible]</visible>
		</item>
		<item id="111">
			<label>הגדלת משך ההשהיה של הכתוביות (השתמשו אם הכתוביות מוצגות מוקדם מדי)</label>
			<property name="timer">https://www.iconsdb.com/icons/preview/white/arrow-204-xxl.png</property>
			<onclick>SubtitleDelayPlus</onclick>
			<visible>$EXP[osdmoviestvshowvisible]</visible>
		</item>
		<item>
			<label>הרץ קדימה</label>
			<icon>osd/fullscreen/buttons/forward.png</icon>
			<visible>Player.SeekEnabled</visible>
			<property name="forward">forward</property>
			<property name="onup">$NUMBER[50001]</property>
			<onclick>Control.SetFocus(50001)</onclick>
		</item>
		<item id="109">
			<label>מעבר לתוכנית הבאה או לא לפרק הבא</label>
			<icon>osd/fullscreen/buttons/next.png</icon>
			<onclick>SkipNext</onclick>
			<visible>Player.Chapter | !String.IsEmpty(VideoPlayer.offset(1).Title)</visible>
		</item>
		</content>
	</control>
</control>
<!-- END OSD MAIN MENU -->

<!-- OSD INFO -->
<include content="PoweredOsdInfo">
<param name="groupheight">550</param>
