<?xml version="1.0" encoding="utf-8"?>
<window type="dialog" id="2118">
	<defaultcontrol always="true">11000</defaultcontrol>
	<include>Animation_DialogPopupOpenClose</include>
	<onunload>ClearProperty(settingslist_header,Home)</onunload>
	<onunload>ClearProperty(settingslist_content,Home)</onunload>
	<controls>
		<control type="group">
			<centerleft>47%</centerleft>
			<height>670</height>
			<centertop>60%</centertop>
			<width>450</width>
			<visible>!Window.IsActive(DialogSettings.xml) + !Window.IsActive(DialogSlider.xml) + !Window.IsActive(GameVideoFilter) + !Window.IsActive(GameStretchMode) + !Window.IsActive(GameControllers) + !Window.IsActive(GameVideoRotation)</visible>
			<animation effect="fade" time="200">VisibleChange</animation>
			<include content="DialogBackgroundCommons">
				<param name="width" value="500" />
				<param name="height" value="600" />
				<param name="header_label" value="$INFO[Window(home).Property(settingslist_Header)]" />
				<param name="header_id" value="1" />
				<param name="diffusetexture" value="masks/landscape-502.png" />
			</include>
			<control type="group" id="11000">
				<left>25</left>
				<top>100</top>
				<control type="grouplist" id="11100">
					<!-- <visible>String.IsEqual(window(home).Property(settingslist_content),osd)</visible> -->
					<width>450</width>
					<height>550</height>
					<itemgap>0</itemgap>
					<onup>11100</onup>
					<ondown>11100</ondown>
					<orientation>vertical</orientation>
					<control type="button" id="11111">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>הורד כתובית</label>
						<onclick>Close</onclick>
						<onclick>ActivateWindow(SubtitleSearch)</onclick>
					</control>
					<control type="button" id="11112">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>שפת כתובית</label>
						<onclick>Close</onclick>
						<onclick>ReplaceWindow(2120)</onclick>
					</control>
					<control type="button" id="11103">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>רקע לכתובית</label>
						<onclick>Close</onclick>
						<onclick>Dialog.Close(VideoOSD)</onclick>
						<onclick>RunPlugin(Skin.SetString(_povil_noop,1))</onclick>
						<visible>VideoPlayer.HasSubtitles</visible>
					</control>
					<control type="button" id="11104">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>גודל כתובית</label>
						<onclick>Close</onclick>
						<onclick>Dialog.Close(VideoOSD)</onclick>
						<onclick>RunPlugin(Skin.SetString(_povil_noop,1))</onclick>
						<visible>VideoPlayer.HasSubtitles</visible>
					</control>
					<control type="button" id="11105">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>אטימות כתובית</label>
						<onclick>Close</onclick>
						<onclick>Dialog.Close(VideoOSD)</onclick>
						<onclick>RunPlugin(Skin.SetString(_povil_noop,1))</onclick>
						<visible>VideoPlayer.HasSubtitles</visible>
					</control>
<!-- 					<control type="button" id="111043">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>צבע כתובית</label>
						<onclick>Close</onclick>
						<onclick>Dialog.Close(VideoOSD)</onclick>
						<onclick>ActivateWindowAndFocus(playersettings, -95,1,-75,colorbutton)</onclick>
						<onclick>Action(Select)</onclick>
						<visible>VideoPlayer.HasSubtitles</visible>
					</control> -->

					<control type="radiobutton" id="11106">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>כבה כתוביות</label>
						<onclick>Action(ShowSubtitles)</onclick>
						<visible>VideoPlayer.HasSubtitles</visible>
					</control>
					<control type="button" id="11107">
						<width>450</width>
						<include>DialogSettingButton</include>
						<label>זרימת שמע</label>
						<label2>$INFO[VideoPlayer.AudioLanguage]</label2>
						<onclick>AudioNextLanguage</onclick>
						<visible>VideoPlayer.HasSubtitles</visible>
						<visible>false</visible>
					</control>
					
				</control>


				<include content="UpDownArrows">
					<param name="container_id" value="11100" />
					<param name="posx" value="326" />
					<param name="up_posy" value="-135" />
					<param name="down_posy" value="400" />
				</include>
			</control>
		</control>
	</controls>
</window>
