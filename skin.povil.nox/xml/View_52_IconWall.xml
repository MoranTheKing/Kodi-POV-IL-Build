<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="View_52_IconWall">
        <control type="group">
			
          <visible>Control.IsVisible(52)</visible>
            <control type="group">
                <control type="group">
                    <include content="VideoList52">
                        <param name="id" value="52" />
                        <param name="name" value="$LOCALIZE[31099]" />
				<param name="condition" value="[Container.Content() + [String.IsEqual(Skin.String(Skin.ForcedView.),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.)) ]] | [Container.Content(movies) + [String.IsEqual(Skin.String(Skin.ForcedView.movies),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.movies)) ]] | [Container.Content(sets) + [String.IsEqual(Skin.String(Skin.ForcedView.sets),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.sets)) ]] | [Container.Content(tvshows) + [String.IsEqual(Skin.String(Skin.ForcedView.tvshows),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.tvshows)) ]] | [Container.Content(seasons) + [String.IsEqual(Skin.String(Skin.ForcedView.seasons),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.seasons)) ]] | [Container.Content(episodes) + [String.IsEqual(Skin.String(Skin.ForcedView.episodes),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.episodes)) ]] | [Container.Content(artists) + [String.IsEqual(Skin.String(Skin.ForcedView.artists),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.artists)) ]] | [Container.Content(albums) + [String.IsEqual(Skin.String(Skin.ForcedView.albums),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.albums)) ]] | [Container.Content(addons) + [String.IsEqual(Skin.String(Skin.ForcedView.addons),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.addons)) ]] | [Container.Content(images) + [String.IsEqual(Skin.String(Skin.ForcedView.images),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.images)) ]] | [Container.Content(videos) + [String.IsEqual(Skin.String(Skin.ForcedView.videos),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.videos)) ]] | [Container.Content(games) + [String.IsEqual(Skin.String(Skin.ForcedView.games),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.games)) ]] | [Container.Content(studios) + [String.IsEqual(Skin.String(Skin.ForcedView.studios),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.studios)) ]] | [Container.Content(musicvideos) + [String.IsEqual(Skin.String(Skin.ForcedView.musicvideos),$LOCALIZE[31099]) | String.IsEmpty(Skin.String(Skin.ForcedView.musicvideos)) ]] | [Container.Content(favourites) + [String.IsEqual(Skin.String(Skin.ForcedView.favourites),$LOCALIZE[31102]) | String.IsEmpty(Skin.String(Skin.ForcedView.favourites)) ]]" />
                    </include>
                </control>
            </control>
        </control>
    </include>
	<include name="VideoList52">
		<control type="group">
			<visible>Control.IsVisible(52)</visible>
			<include>OpenClose_Right</include>
			<include>Visible_Right</include>
			<control type="panel" id="$PARAM[id]">
				<centerleft>51.2%</centerleft>
				<top>0</top>
				<width>92%</width>
				<height>100%</height>
				<onleft>9000</onleft>
				<onright>531</onright>
				<pagecontrol>531</pagecontrol>
				<preloaditems>2</preloaditems>
				<onup>52</onup>
				<ondown>52</ondown>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<visible>Container.Content() | Container.Content(files) | Container.Content(tags) | Container.Content(years) | Container.Content(roles) | Container.Content(sources) | Container.Content(genres) | Container.Content(countries) | Container.Content(studios) | Container.Content(playlists) | Container.Content(favourites) | Container.Content(unknown)</visible>
				<viewtype label="$PARAM[name]">icon</viewtype>
				<visible>$PARAM[condition]</visible>
				<itemlayout height="280" width="440" condition="Container.Content() | Container.Content(files) | Container.Content(tags) | Container.Content(playlists) | [Container.Content(studios) + System.AddonIsEnabled(resource.images.studios.white)]">
					<control type="group">
						<top>150</top>
						<control type="image">
							<width>396</width>
							<height>245</height>
							<texture colordiffuse="button_focus2">masks/landscape-unfocused.png</texture>
							<!-- <bordertexture border="21" infill="false">overlays/shadow.png</bordertexture> -->
							<bordersize>20</bordersize>
						</control>
						<!-- IMAGE CONTROL -->
						<control type="image">
							<left>120</left>
							<top>35</top>
							<width>160</width>
							<height>130</height>
							<texture colordiffuse="unfocused_text" fallback="DefaultStudios.png">$VAR[IconWallThumbVar]</texture>
							<aspectratio>keep</aspectratio>
							<align>center</align>
						</control>
						<control type="textbox">
							<left>35</left>
							<top>148</top>
							<width>340</width>
							<height>74</height>
							<font>font12</font>
							<label>$INFO[ListItem.Label]</label>
							<textcolor>unfocused_text</textcolor>
							<align>center</align>
							<aligny>center</aligny>
						</control>
					</control>
				</itemlayout>
				<focusedlayout height="280" width="440" condition="Container.Content() | Container.Content(files) | Container.Content(tags) | Container.Content(playlists) | [Container.Content(studios) + System.AddonIsEnabled(resource.images.studios.white)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>150</top>
						<control type="image">
							<include>FocusBounce</include>
							<width>396</width>
							<height>245</height>
							<texture colordiffuse="button_focus">masks/landscape.png</texture>
							<bordersize>15</bordersize>
							<include>Animation_FocusTextureFade</include>
						</control>
						<control type="image">
							<width>396</width>
							<height>245</height>
							<texture colordiffuse="dialog_bg">masks/landscape-unfocused.png</texture>
							<!-- <bordertexture border="21" infill="false">overlays/shadow.png</bordertexture> -->
							<bordersize>20</bordersize>
						</control>
						<control type="image">
							<left>120</left>
							<top>35</top>
							<width>160</width>
							<height>130</height>
							<texture colordiffuse="unfocused_text" fallback="DefaultStudios.png">$VAR[IconWallThumbVar]</texture>
							<aspectratio>keep</aspectratio>
							<align>center</align>
						</control>
						<control type="textbox">
							<left>35</left>
							<top>148</top>
							<width>340</width>
							<height>74</height>
							<font>font12</font>
							<label>$INFO[ListItem.Label]</label>
							<textcolor>unfocused_text</textcolor>
							<align>center</align>
							<aligny>center</aligny>
						</control>
					</control>
				</focusedlayout>
				<itemlayout height="181" width="348" condition="Container.Content(genres) | Container.Content(sources) | Container.Content(years) | Container.Content(roles) | Container.Content(countries) | [Container.Content(studios) + !System.AddonIsEnabled(resource.images.studios.white)]">
					<control type="group">
						<top>120</top>
						<control type="image">
							<width>330</width>
							<height>140</height>
							<texture>dialogs/dialog-bg-nobo.png</texture>
							<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
							<bordersize>20</bordersize>
						</control>
						<control type="textbox">
							<left>30</left>
							<top>0</top>
							<width>270</width>
							<height>140</height>
							<label>$INFO[ListItem.Label]</label>
							<align>center</align>
							<aligny>center</aligny>
						</control>
					</control>
				</itemlayout>
				<focusedlayout height="181" width="348" condition="Container.Content(genres) | Container.Content(sources) | Container.Content(years) | Container.Content(roles) | Container.Content(countries) | [Container.Content(studios) + !System.AddonIsEnabled(resource.images.studios.white)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>120</top>
						<control type="image">
							<width>330</width>
							<height>140</height>
							<texture>dialogs/dialog-bg-nobo.png</texture>
							<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
							<bordersize>20</bordersize>
						</control>
						<control type="image">
							<width>330</width>
							<height>140</height>
							<texture colordiffuse="button_focus2">colors/grey.png</texture>
							<bordersize>20</bordersize>
							<include>Animation_FocusTextureFade</include>
						</control>
						<control type="textbox">
							<left>30</left>
							<top>0</top>
							<width>270</width>
							<height>140</height>
							<label>$INFO[ListItem.Label]</label>
							<align>center</align>
							<aligny>center</aligny>
						</control>
					</control>
				</focusedlayout>
			</control>
		</control>
	</include>
</includes>
