<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="View_504_WideWall">
        <control type="group">
			
          <visible>Control.IsVisible(504)</visible>
            <control type="group">
                <control type="group">
                    <include content="VideoList504">
                        <param name="id" value="504" />
                        <param name="name" value="$LOCALIZE[70007]" />
				<param name="condition" value="[Container.Content() + [String.IsEqual(Skin.String(Skin.ForcedView.),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.)) ]] | [Container.Content(movies) + [String.IsEqual(Skin.String(Skin.ForcedView.movies),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.movies)) ]] | [Container.Content(sets) + [String.IsEqual(Skin.String(Skin.ForcedView.sets),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.sets)) ]] | [Container.Content(tvshows) + [String.IsEqual(Skin.String(Skin.ForcedView.tvshows),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.tvshows)) ]] | [Container.Content(seasons) + [String.IsEqual(Skin.String(Skin.ForcedView.seasons),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.seasons)) ]] | [Container.Content(episodes) + [String.IsEqual(Skin.String(Skin.ForcedView.episodes),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.episodes)) ]] | [Container.Content(artists) + [String.IsEqual(Skin.String(Skin.ForcedView.artists),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.artists)) ]] | [Container.Content(albums) + [String.IsEqual(Skin.String(Skin.ForcedView.albums),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.albums)) ]] | [Container.Content(addons) + [String.IsEqual(Skin.String(Skin.ForcedView.addons),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.addons)) ]] | [Container.Content(images) + [String.IsEqual(Skin.String(Skin.ForcedView.images),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.images)) ]] | [Container.Content(videos) + [String.IsEqual(Skin.String(Skin.ForcedView.videos),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.videos)) ]] | [Container.Content(games) + [String.IsEqual(Skin.String(Skin.ForcedView.games),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.games)) ]] | [Container.Content(studios) + [String.IsEqual(Skin.String(Skin.ForcedView.studios),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.studios)) ]] | [Container.Content(musicvideos) + [String.IsEqual(Skin.String(Skin.ForcedView.musicvideos),$LOCALIZE[70007]) | String.IsEmpty(Skin.String(Skin.ForcedView.musicvideos)) ]]" />
                    </include>
                </control>
            </control>
        </control>
    </include>
	<include name="VideoList504">
		<control type="group">
			<include>OpenClose_Right</include>
			<left>50</left>
			<top>0</top>
			<visible>Control.IsVisible(504)</visible>
			<include>Visible_Right</include>
			<control type="panel" id="$PARAM[id]">
				<left>-10</left>
				<top>-20</top>
				<width>102%</width>
				<height>102%</height>
				<onleft>9000</onleft>
				<onright>531</onright>
				<onup condition="Integer.IsGreater(Container.NumPages,1)">$PARAM[id]</onup>
				<onup condition="!Integer.IsGreater(Container.NumPages,1)">9000</onup>
				<ondown>$PARAM[id]</ondown>
				<viewtype label="$PARAM[name]">icon</viewtype>
				<visible>$PARAM[condition]</visible>
				<preloaditems>2</preloaditems>
				<pagecontrol>531</pagecontrol>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<visible>Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(artists) | Container.Content(albums) | Container.Content(musicvideos) | Container.Content(addons) | Container.Content(images) | Container.Content(videos) | Container.Content(games) | Container.Content(favourites)</visible>
				<itemlayout height="305" width="460" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<top>130</top>
						<include content="BigWideInfoWallMovieLayout">
						<param name="focused" value="false" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="305" width="460" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>130</top>
						<include content="BigWideInfoWallMovieLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
			</control>
		</control>
	</include>
</includes>
