<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="View_502_FanArt">
        <control type="group">
			
          <visible>Control.IsVisible(502)</visible>
            <control type="group">
                <control type="group">
                    <include content="VideoList502">
                        <param name="id" value="502" />
                        <param name="name" value="$LOCALIZE[20445]" />
				<param name="condition" value="[Container.Content() + [String.IsEqual(Skin.String(Skin.ForcedView.),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.)) ]] | [Container.Content(movies) + [String.IsEqual(Skin.String(Skin.ForcedView.movies),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.movies)) ]] | [Container.Content(sets) + [String.IsEqual(Skin.String(Skin.ForcedView.sets),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.sets)) ]] | [Container.Content(tvshows) + [String.IsEqual(Skin.String(Skin.ForcedView.tvshows),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.tvshows)) ]] | [Container.Content(seasons) + [String.IsEqual(Skin.String(Skin.ForcedView.seasons),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.seasons)) ]] | [Container.Content(episodes) + [String.IsEqual(Skin.String(Skin.ForcedView.episodes),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.episodes)) ]] | [Container.Content(artists) + [String.IsEqual(Skin.String(Skin.ForcedView.artists),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.artists)) ]] | [Container.Content(albums) + [String.IsEqual(Skin.String(Skin.ForcedView.albums),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.albums)) ]] | [Container.Content(addons) + [String.IsEqual(Skin.String(Skin.ForcedView.addons),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.addons)) ]] | [Container.Content(images) + [String.IsEqual(Skin.String(Skin.ForcedView.images),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.images)) ]] | [Container.Content(videos) + [String.IsEqual(Skin.String(Skin.ForcedView.videos),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.videos)) ]] | [Container.Content(games) + [String.IsEqual(Skin.String(Skin.ForcedView.games),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.games)) ]] | [Container.Content(studios) + [String.IsEqual(Skin.String(Skin.ForcedView.studios),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.studios)) ]] | [Container.Content(musicvideos) + [String.IsEqual(Skin.String(Skin.ForcedView.musicvideos),$LOCALIZE[20445]) | String.IsEmpty(Skin.String(Skin.ForcedView.musicvideos)) ]]" />
                    </include>
                </control>
            </control>
        </control>
    </include>
	<include name="VideoList502">
		<control type="group">
			<include>OpenClose_Left</include>
			<visible>Control.IsVisible(502)</visible>
			<include>Visible_Left</include>
			<control type="fixedlist" id="$PARAM[id]">
				<left>$PARAM[left]</left>
				<right>$PARAM[right]</right>
				<top>list_top_offset</top>
				<bottom>list_bottom_offset</bottom>
				<movement>7</movement>
				<focusposition>6</focusposition>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<orientation>vertical</orientation>
				<pagecontrol>$PARAM[id]600</pagecontrol>
				<onleft>9000</onleft>
				<onright>$PARAM[id]600</onright>
				<onup>$PARAM[id]</onup>
				<ondown>$PARAM[id]</ondown>
				<viewtype label="$PARAM[name]">list</viewtype>
				<visible>$PARAM[condition]</visible>
				<visible>Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(games) | Window.IsActive(videoplaylist) | Window.IsActive(musicplaylist)</visible>
				<focusedlayout height="85">
					<control type="label">
						<left>70</left>
						<right>20</right>
						<top>0</top>
						<bottom>0</bottom>
						<aligny>center</aligny>
						<scroll>true</scroll>
						<scrollspeed>300</scrollspeed>
						<font>font52_title</font>
						<label>$VAR[ListLabelVar]</label>
						<shadowcolor>text_shadow</shadowcolor>
					</control>
					<control type="label">
						<top>0</top>
						<bottom>0</bottom>
						<left>100</left>
						<right>20</right>
						<align>right</align>
						<aligny>center</aligny>
						<font>font32</font>
						<label>[B]$INFO[ListItem.Property(WatchedEpisodes)]$INFO[ListItem.Property(TotalEpisodes), / ,][/B]</label>
						<animation effect="fade" start="70" end="100" time="300" reversible="false">Focus</animation>
						<shadowcolor>text_shadow</shadowcolor>
					</control>
					<control type="image">
						<left>15</left>
						<centertop>50%</centertop>
						<width>37</width>
						<height>37</height>
						<texture>$VAR[ListWatchedIconVar]</texture>
						<animation effect="fade" start="30" end="100" time="300" reversible="false">Focus</animation>
					</control>
					<control type="image">
						<left>15</left>
						<centertop>50%</centertop>
						<width>37</width>
						<height>37</height>
						<texture colordiffuse="button_focus">$VAR[ListWatchedIconVar]</texture>
						<animation effect="fade" start="0" end="100" time="300" reversible="false">Focus</animation>
						<animation effect="fade" time="150">VisibleChange</animation>
						<visible>!Control.HasFocus($PARAM[list_id])</visible>
					</control>
				</focusedlayout>
				<itemlayout height="list_item_height">
					<control type="label">
						<left>70</left>
						<right>20</right>
						<top>0</top>
						<bottom>0</bottom>
						<aligny>center</aligny>
						<font>font32</font>
						<textcolor>unfocused_text</textcolor>
						<label>$VAR[ListLabelVar]</label>
						<shadowcolor>text_shadow</shadowcolor>
					</control>
					<control type="label">
						<left>20</left>
						<right>20</right>
						<top>0</top>
						<bottom>0</bottom>
						<align>right</align>
						<aligny>center</aligny>
						<font>font27</font>
						<textcolor>unfocused_text</textcolor>
						<label>$INFO[ListItem.Property(WatchedEpisodes)]$INFO[ListItem.Property(TotalEpisodes), / ,]</label>
						<shadowcolor>text_shadow</shadowcolor>
					</control>
					<control type="image">
						<left>15</left>
						<centertop>50%</centertop>
						<width>37</width>
						<height>37</height>
						<texture colordiffuse="grey">$VAR[ListWatchedIconVar]</texture>
					</control>
				</itemlayout>
			</control>
		</control>
		<control type="group">
			<depth>DepthContentPanel</depth>
			<include>OpenClose_Right</include>
			<visible>Control.IsVisible(502)</visible>
			<include>Visible_Right</include>
			<control type="group">
				<right>-20</right>
				<width>1235</width>
				<include content="ContentPanel">
					<param name="width" value="1235" />
					<param name="left" value="0" />
					<param name="top" value="-20" />
					<param name="flipx" value="true" />
				</include>
				<control type="image">
					<left>38</left>
					<right>36</right>
					<top>115</top>
					<height>644</height>
					<fadetime>300</fadetime>
					<texture diffuse="masks/landscape-502.png" border="2" fallback="special://skin/extras/home-images/movie.jpg" background="true">$VAR[FanartImageVar]</texture>
					<!-- <aspectratio align="center" aligny="bottom">keep</aspectratio> -->
				</control>
				<control type="group">
					<left>1152</left>
					<top>97</top>
					<include content="RatingCircle" condition="Skin.HasSetting(circle_rating) | Skin.HasSetting(circle_userrating)">
						<param name="left">-72</param>
						<param name="top">17</param>
						<param name="width">119</param>
						<param name="height">119</param>
						<param name="label-left">-18</param>
						<param name="label-top">32</param>
						<param name="cornerdiffuse">overlays/overlaybg5.png</param>
					</include>
				</control>
				<control type="textbox">
					<left>50</left>
					<right>50</right>
					<top>805</top>
					<bottom>105</bottom>
					<label>$VAR[PlotTextBoxVar]</label>
					<autoscroll time="3000" delay="7000" repeat="5000">!System.HasActiveModalDialog + Skin.HasSetting(AutoScroll)</autoscroll>
				</control>
				<include content="ProgressBar">
					<!-- 38 -->
					<param name="left" value="100"/>
					<param name="top" value="737"/>
					<param name="width" value="1040"/>
				</include>
				<control type="scrollbar" id="502600">
					<left>20</left>
					<top>list_top_offset</top>
					<width>12</width>
					<bottom>list_bottom_offset</bottom>
					<onleft>502</onleft>
					<onright>502</onright>
					<orientation>vertical</orientation>
					<animation effect="zoom" end="50,100" time="300" tween="sine" center="20,0" easing="inout" condition="!Control.HasFocus(502600)">conditional</animation>
				</control>
				<control type="group">
					<left>40</left>
					<top>770</top>
					<visible>ListItem.IsCollection + String.IsEmpty(ListItem.PlotOutline) + String.IsEmpty(ListItem.Plot)</visible>
					<include content="InfoList">
						<param name="bottom" value="108" />
						<param name="width" value="1000" />
						<param name="sortby" value="year" />
						<param name="sortorder" value="ascending" />
						<param name="font" value="font13" />
					</include>
				</control>
			</control>
		</control>
	</include>
</includes>
