                            </control>
                            <control type="label">
                                <right>25</right>
                                <top>20</top>
								<font>font36_title</font>
                                <align>right</align>
                                <bottom>pad</bottom>
                                <label>$INFO[ListItem.Label]</label>
                            </control>
                        </itemlayout>
                        <focusedlayout width="560" height="100">
