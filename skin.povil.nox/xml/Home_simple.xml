<?xml version="1.0" encoding="UTF-8"?>
<includes>
<include name="skin_home_pellucid">
	<defaultcontrol always="true">9000</defaultcontrol>
		<controls>
		
		<include>DefaultBackground</include>
		<control type="multiimage">
			<depth>DepthBackground</depth>
			<include>FullScreenDimensions</include>
			<aspectratio>scale</aspectratio>
			<fadetime>600</fadetime>
			<imagepath background="true" colordiffuse="bg_overlay">$VAR[HomeFanartVarNox]</imagepath>
			<visible>!Player.HasMedia</visible>
		</control>
			<include content="TopBar">
				<param name="breadcrumbs_label" value="" />
			</include>
										<!-- תפריט ראשי -->
		
		<control type="panel" id="9000">
			<animation type="conditional" condition="control.hasfocus(9999)" reversible="true">
				<effect type="fade" start="100" end="0" time="500" delay="0"/>
			</animation>
			 <left>220</left>
			<animation condition="!Skin.HasSetting(HomeMenuNoCustom4Button)" effect="slide" end="-130" time="0">conditional</animation>
			<top>500</top>
			<width>1920</width>
			<height>432</height>
			<ondown>700</ondown>
			<preloaditems>2</preloaditems>
			<ondown>setfocus(902012,1)</ondown>
			<orientation>vertical</orientation>
			<itemlayout width="250" height="100">
				<control type="image">
					<posx>0</posx>
					<posy>0</posy>
					<width>245</width>
					<height>105</height>
					<texture>colors/black.png</texture>
					<colordiffuse>black</colordiffuse>
					<aspectratio>stretch</aspectratio>
				</control>
				<control type="label">
				   <centerleft>50%</centerleft>
					<align>center</align>
					<font>font36_title</font>
					<top>23</top>
					<bottom>pad</bottom>
					<textcolor>fff0f0f0</textcolor>
					<label>$INFO[ListItem.Label]</label>
				</control>
			</itemlayout>
			<focusedlayout width="250" height="100">
				<control type="image">
					<posx>0</posx>
					<posy>0</posy>
					<width>245</width>
					<height>105</height>
					<texture>colors/white.png</texture>
					<colordiffuse>ffe52b50</colordiffuse>
					<aspectratio>stretch</aspectratio>
				</control>
					<control type="label">
					   <centerleft>50%</centerleft>
						<align>center</align>
						<font>font36_title</font>
						<top>23</top>
						<bottom>pad</bottom>
						<textcolor>fff0f0f0</textcolor>
						<label>$INFO[ListItem.Label]</label>
					</control>
			</focusedlayout>
			<content>
					<item>
						<label>סרטים</label>
						<icon>special://skin/extras/icons/kan11.png</icon>
						<onclick>ActivateWindow(2101)</onclick>
					</item>
					<item>
						<label>סדרות</label>
						<icon>special://skin/extras/icons/12.png</icon>
						<onclick>ActivateWindow(2102)</onclick>
					</item>
					<item>
						<label>טורקיות</label>
						<onclick>ActivateWindow(2110)</onclick>
						<thumb>icons/sidemenu/tv.png</thumb>
						<visible>!Skin.HasSetting(HomeMenuNoCustom4Button)</visible>
					</item>
					<item>
						<label>תוכן ישראלי</label>
						<icon>special://skin/extras/icons/13.png</icon>
						<onclick>ActivateWindow(2103)</onclick>

					</item>
					<item>
						<label>טלויזיה ורדיו</label>
						<icon>special://skin/extras/icons/14vod.png</icon>
						<onclick>ActivateWindow(2104)</onclick>
					</item>
					<item>
						<label>ילדים</label>
						<icon>special://skin/extras/icons/23.png</icon>
						<onclick>ActivateWindow(2105)</onclick>
					</item>
					<item>
						<label>$LOCALIZE[10134]</label>
						<icon>special://skin/extras/icons/244.png</icon>
						<onclick>ActivateWindow(favouritesbrowser)</onclick>
					</item>

			</content>
		</control>
									<!-- כפתורים -->	
					<control type="image">
						<top>930</top>
						<centerleft>50%</centerleft>
						<width>450</width>
						<height>60</height>
						<texture colordiffuse="black">masks/categorywidget.png</texture>
					</control>

					<control type="grouplist" id="700">
						<orientation>horizontal</orientation>
						<itemgap>0</itemgap>
						<centerleft>50%</centerleft>
						<width>480</width>
						<height>110</height>
						<top>900</top>
						<onup>SetFocus(9000,99,absolute)</onup>
						<ondown>SetFocus(9000,0,absolute)</ondown>
						<onright>2000</onright>
						<align>justify</align>
						<include content="IconButtonNox">
							<param name="control_id" value="807" />
							<param name="onclick" value="Fullscreen" />
							<param name="icon" value="icons/now-playing/fullscreen.png" />
							<param name="label" value="$LOCALIZE[31000]" />
							<param name="visible" value="Player.HasMedia" />
						</include>
						<include content="IconButtonNox" condition="!Skin.HasSetting(NoSearchResultsWindow) + !Skin.HasSetting(DefaultSearchWindowBehavior)">
							<param name="control_id" value="806" />
							<!-- <param name="onclick" value="RunScript(script.fentastic.helper,mode=open_search_window)" /> -->
							<param name="onclick" value="ActivateWindow(10025,&quot;plugin://plugin.video.idanplus/?name=VOD&amp;url=&amp;mode=2&amp;iconimage=special%3A%2F%2Fhome%2Faddons%2Fplugin.video.idanplus%2Ficon.png&amp;module=&amp;moredata=)" />
							<param name="icon" value="icons/search.png" />
							<param name="label" value="$LOCALIZE[137]" />
						</include>
						<include content="IconButtonNox">
							<param name="control_id" value="8005" />
							<param name="onclick" value="ActivateWindow(2115)" />
							<param name="icon" value="icons/trakt-icon-white.png" />
							<param name="label" value="המשך צפייה" />
						</include>
						<include content="IconButtonNox" condition="!Skin.HasSetting(NoSearchResultsWindow) + Skin.HasSetting(DefaultSearchWindowBehavior)">
							<param name="control_id" value="805" />
							<param name="onclick" value="RunScript(script.fentastic.helper,mode=search_input)" />
							<param name="icon" value="icons/search.png" />
							<param name="label" value="$LOCALIZE[137]" />
						</include>
						<include content="IconButtonNox" condition="Skin.HasSetting(NoSearchResultsWindow)">
							<param name="control_id" value="804" />
							<param name="onclick" value="ActivateWindow(1107)" />
							<param name="icon" value="icons/search.png" />
							<param name="label" value="$LOCALIZE[137]" />
						</include>
						<include content="IconButtonNox">
							<param name="control_id" value="803" />
							<param name="onclick" value="ActivateWindow(2107)" />
							<param name="icon" value="icons/settings.png" />
							<param name="label" value="$LOCALIZE[21417]" />
						</include>
						<include content="IconButtonNox" condition="!Skin.HasSetting(OneClickClose)">
							<param name="control_id" value="802" />
							<param name="onclick" value="ActivateWindow(shutdownmenu)" />
							<param name="icon" value="icons/power.png" />
							<param name="label" value="$LOCALIZE[33060]" />
						</include>
					</control>


															<!-- RSS -->	
		
			<control type="group">
				<depth>DepthBars</depth>
				<bottom>0</bottom>
				<height>70</height>

<!-- 				<include condition="!Skin.HasSetting(hide_mediaflags)" content="MediaFlags">
					<param name="infolabel_prefix" value="Container." />
					<param name="resolution_var" value="$VAR[ContainerResolutionFlagVar]" />
				</include> -->
				<control type="rss">
					<animation effect="slide" end="0,90" time="300" tween="sine" easing="inout" condition="$EXP[infodialog_active]">conditional</animation>
					<!-- <left>220</left> -->
					<left>20</left>
					<bottom>0</bottom>
					<height>39</height>
					<width>100%</width>
					<font>font12</font>
					<urlset>1</urlset>
					<hitrect x="-100" y="0" w="1" h="1" />
					<titlecolor>button_focus</titlecolor>
					<textcolor>button_focus</textcolor>
					<shadowcolor>text_shadow</shadowcolor>
					<headlinecolor>FFC0C0C0</headlinecolor>
					<visible>Skin.HasSetting(hide_mediaflags) | !ControlGroup(2000).HasFocus</visible>
					<animation effect="fade" time="300">VisibleChange</animation>
				</control>
			</control>
<!-- 			<control type="group">
				<top>1041</top>
				<left>0</left>
				<animation effect="fade" time="300">VisibleChange</animation>
				<visible>Skin.HasSetting(hide_mediaflags) | !ControlGroup(2000).HasFocus</visible>
				<include>fastupdate</include>
			</control> -->
			<control type="group">
        <animation effect="slide" time="300" start="-492,0" end="0,0" tween="sine" easing="inout">VisibleChange</animation>
        <visible>![String.IsEqual(ListItem.DBtype,movie) | String.IsEqual(ListItem.DBtype,tvshow) | String.IsEqual(ListItem.DBtype,season) | String.IsEqual(ListItem.DBtype,episode)] + !Skin.HasSetting(TrailerPlaying)</visible>
				<depth>DepthBars</depth>
				<top>35</top>
				<left>35</left>
        <control type="image">
		<visible>Skin.HasSetting(HomeMenuNoCustom4Button)</visible>
          <left>19</left>
          <top>0</top>
          <aspectratio>keep</aspectratio>
          <width>130</width>
          <height>56</height>
          <texture>special://skin/media/logos/K-logo.png</texture>
        </control>
        <control type="image">
		<visible>Skin.HasSetting(HomeMenuNoCustom4Button)</visible>
          <left>120</left>
          <top>0</top>
          <aspectratio>keep</aspectratio>
          <width>230</width>
          <height>50</height>
          <texture>special://skin/media/logos/letters.png</texture>
        </control>
		<control type="image">
		<visible>!Skin.HasSetting(HomeMenuNoCustom4Button)</visible>
		  <left>10</left>
		  <top>0</top>
		  <aspectratio>keep</aspectratio>
		  <width>170</width>
		  <height>50</height>
		  <texture>special://skin/media/logos/dragon_letters.png</texture>
		</control>
			</control>
		</controls>
	</include>
</includes>
