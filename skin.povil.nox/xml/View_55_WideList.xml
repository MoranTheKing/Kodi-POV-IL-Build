						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$VAR[ListLabelVar]</label>
							<shadowcolor>text_shadow</shadowcolor>
						</control>
						<control type="label">
							<left>105</left>
							<top>0</top>
							<bottom>0</bottom>
							<right>40</right>
							<align>right</align>
							<aligny>center</aligny>
							<font>font32</font>
							<textcolor>unfocused_text</textcolor>
							<label>$VAR[ListLabel2Var]</label>
							<shadowcolor>text_shadow</shadowcolor>
