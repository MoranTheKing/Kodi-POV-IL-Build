						<description>Watched Toggle</description>
						<include>MediaMenuItemsCommon</include>
						<label>$LOCALIZE[20367]</label>
						<label2>[B]$INFO[Container.NumItems][/B]</label2>
						<visible>Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.content(seasons) | Container.Content(episodes) | Container.Content(MusicVideos)</visible>
					</control>
					<control type="label" id="203">
						<include>MediaMenuLabelCommon</include>
						<label>$LOCALIZE[31020]</label>
					</control>
					<control type="button" id="152">
						<description>enable torrent</description>
						<include>MediaMenuItemsCommon</include>
						<label>$LOCALIZE[70009]</label>
						<onclick>RunPlugin(plugin://plugin.video.pov/?mode=play_from_bot)</onclick>
						<onclick>close</onclick>
						<visible>String.Contains(ListItem.Folderpath, plugin.video.pov)|String.Contains(ListItem.Folderpath, plugin.video.telemedia)</visible>
					</control>
					<control type="button" id="153">
						<description>enable torrent</description>
						<include>MediaMenuItemsCommon</include>
						<label>$LOCALIZE[70010]</label>
						<onclick>RunPlugin(plugin://plugin.video.pov/?mode=show_torrent_sources)</onclick>
						<onclick>close</onclick>
						<visible>String.Contains(ListItem.Folderpath, plugin.video.pov)</visible>
